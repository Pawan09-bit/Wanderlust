<%- layout("/layouts/boilerplate") %>

<script>
    const mapToken = "<%= process.env.MAP_TOKEN %>";
    const listing = "<%- JSON.stringify(listing) %>";
</script>

<div class="row">
    <div class="col-8 offset-2">
        <h3><%= listing.title %></h3>
    </div>

    <div class="card col-6 offset-3 show-card listing-card">
        <img 
          src="<%= listing.image?.url %>" 
          class="card-img-top" 
          alt="listing_image" 
          style="height: 20rem; object-fit: cover;"
        >

        <div class="card-body">
            <p class="card-text">
                <i>Owned by: <%= listing.owner.username %></i>
            </p>

            <p class="card-text">
                <%= listing.description %>
            </p>

            <p class="card-text">
                ₹ <%= listing.price.toLocaleString("en-IN") %>
            </p>

            <p class="card-text">
                <%= listing.location %>, <%= listing.country %>
            </p>
        </div>
    </div>

    <br>

<% if(currUser && currUser._id.equals(listing.owner._id)) { %>    
    <div class="btns text-center mb-3">
        <a href="/listings/<%= listing._id %>/edit" 
           class="btn btn-dark">
           Edit
        </a>

        <form method="POST" 
              action="/listings/<%= listing._id %>?_method=DELETE" 
              class="d-inline">
            <button class="btn btn-danger">
                Delete
            </button> 
        </form>
    </div> 
<% } %>

<div class="col-8 offset-2 mb-3">
    <hr />

    <% if(currUser) { %>
        <h4>Leave a Review</h4>

        <form action="/listings/<%= listing._id %>/reviews" 
              method="POST" 
              novalidate 
              class="needs-validation">

            <div class="mb-3 mt-3">
                <label class="form-label">Rating</label>

                <fieldset class="starability-slot">
                    <input type="radio" name="review[rating]" value="1" />
                    <label>1 star</label>

                    <input type="radio" name="review[rating]" value="2" />
                    <label>2 stars</label>

                    <input type="radio" name="review[rating]" value="3" />
                    <label>3 stars</label>

                    <input type="radio" name="review[rating]" value="4" />
                    <label>4 stars</label>

                    <input type="radio" name="review[rating]" value="5" checked />
                    <label>5 stars</label>
                </fieldset>
            </div>

            <div class="mb-3 mt-3">
                <label for="comment">Comment</label>
                <textarea name="review[comment]" 
                          id="comment" 
                          rows="4" 
                          class="form-control" 
                          required></textarea>
                <div class="invalid-feedback">
                    Please add a comment.
                </div>
            </div>

            <button class="btn btn-outline-dark">
                Submit
            </button>
        </form>

        <hr/>
    <% } %>

    <% if(listing.reviews.length > 0) { %>
        <div class="row">
            <p><b>All Reviews</b></p>

            <% for(let review of listing.reviews) { %>
                <div class="card col-5 ms-3 mb-3">
                    <div class="card-body">
                        <h5 class="card-title">
                            <%= review.author.username %>
                        </h5>

                        <p class="card-text">
                            Rating: <%= review.rating %>
                        </p>

                        <p class="card-text">
                            <%= review.comment %>
                        </p>
                    </div>

                    <% if(currUser && currUser._id.equals(review.author._id)) { %>
                    <form class="mb-3 ms-3" 
                          method="POST" 
                          action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                        <button class="btn btn-sm btn-dark">
                            Delete
                        </button>
                    </form>
                    <% } %>
                </div>
            <% } %>
        </div>
    <% } %>

    <div class="col-12 mt-4">
        <h3>Where you'll be</h3>
        <div id="map" style="height: 400px;"></div>
    </div>

</div>

<script src="/js/map.js"></script>